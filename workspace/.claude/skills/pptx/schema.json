{
  "skill": "pptx",
  "version": "1.0.0",
  "input": {
    "required": {
      "task": "string — plain language description (e.g. 'create a 5-slide intro deck', 'update slide 3 title', 'extract all speaker notes')"
    },
    "optional": {
      "source_file": "path — input .pptx file",
      "output_file": "path — where to save output",
      "theme": "string — theme/color palette name",
      "slide_range": "string — slide range e.g. '1-3' or '2,4,6'"
    },
    "context": {
      "project": "string",
      "parent_task": "string",
      "dependencies": ["skill-name"]
    }
  },
  "output": {
    "status": "success|error|dependency-needed",
    "result": "any — extracted content or operation summary",
    "dependency_requests": [{"skill": "string", "task": "string", "reason": "string"}],
    "files_created": ["path"],
    "error": "string if status=error"
  }
}
