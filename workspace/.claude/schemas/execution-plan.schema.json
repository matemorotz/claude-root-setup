{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://claude-code.dev/schemas/execution-plan.schema.json",
  "title": "Execution Plan",
  "description": "Structured execution plan with haiku-optimized steps",
  "version": "1.0.0",
  "type": "object",
  "required": ["version", "plan_id", "created", "project", "context_summary", "sections"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "plan_id": {
      "type": "string"
    },
    "created": {
      "type": "string",
      "format": "date-time"
    },
    "updated": {
      "type": "string",
      "format": "date-time"
    },
    "project": {
      "type": "object",
      "required": ["name", "location"],
      "properties": {
        "name": {"type": "string"},
        "location": {"type": "string"}
      }
    },
    "context_summary": {
      "type": "object",
      "properties": {
        "goal": {"type": "string"},
        "current_state": {"type": "string"},
        "priority": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
        "estimated_complexity": {"type": "string", "enum": ["simple", "moderate", "complex", "very_complex"]}
      }
    },
    "seed_rules_applied": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "level": {"type": "string", "enum": ["project", "section", "task", "step"]},
          "name": {"type": "string"},
          "rule": {"type": "string"}
        }
      }
    },
    "sections": {
      "type": "array",
      "items": {"$ref": "#/definitions/section"}
    },
    "parallel_groups": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "group_id": {"type": "string"},
          "section_ids": {"type": "array", "items": {"type": "string"}},
          "reason": {"type": "string"}
        }
      }
    },
    "dependencies": {
      "type": "object",
      "description": "Explicit step dependencies for parallel execution optimization",
      "additionalProperties": {
        "type": "array",
        "items": {"type": "string"},
        "description": "Step IDs this step depends on"
      },
      "example": {
        "1.1": [],
        "1.2": ["1.1"],
        "2.1": ["1.1"],
        "2.2": ["2.1", "1.2"]
      }
    },
    "success_criteria": {
      "type": "array",
      "items": {"type": "string"}
    },
    "metadata": {
      "type": "object",
      "properties": {
        "created_by": {"type": "string"},
        "model_used": {"type": "string"},
        "total_steps": {"type": "integer"},
        "total_sections": {"type": "integer"}
      }
    }
  },
  "definitions": {
    "section": {
      "type": "object",
      "required": ["section_id", "title", "steps"],
      "properties": {
        "section_id": {"type": "string"},
        "title": {"type": "string"},
        "description": {"type": "string"},
        "status": {"type": "string", "enum": ["pending", "in_progress", "completed", "blocked", "skipped"], "default": "pending"},
        "dependencies": {"type": "array", "items": {"type": "string"}},
        "resources_needed": {
          "type": "object",
          "properties": {
            "documentation": {"type": "array", "items": {"type": "string"}},
            "code_files": {"type": "array", "items": {"type": "string"}},
            "research": {"type": "array", "items": {"type": "string"}},
            "external_apis": {"type": "array", "items": {"type": "string"}}
          }
        },
        "steps": {"type": "array", "items": {"$ref": "#/definitions/step"}},
        "success_criteria": {"type": "array", "items": {"type": "string"}}
      }
    },
    "step": {
      "type": "object",
      "required": ["step_id", "action", "agent_type"],
      "properties": {
        "step_id": {"type": "string"},
        "action": {"type": "string"},
        "status": {"type": "string", "enum": ["pending", "in_progress", "completed", "error", "skipped"], "default": "pending"},
        "agent_type": {"type": "string", "enum": ["haiku-executor", "sonnet-debugger", "sonnet-tracker", "opus-planner", "research-agent"]},
        "model": {"type": "string", "enum": ["haiku", "sonnet", "opus"]},
        "context": {
          "type": "object",
          "properties": {
            "files": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "path": {"type": "string"},
                  "sections": {"type": "array", "items": {"type": "string"}},
                  "load_full": {"type": "boolean", "default": false}
                }
              }
            },
            "research_refs": {"type": "array", "items": {"type": "string"}},
            "inline_context": {"type": "string"},
            "seed_rules": {"type": "array", "items": {"type": "string"}}
          }
        },
        "expected_outcome": {"type": "string"},
        "validation": {
          "type": "object",
          "properties": {
            "type": {"type": "string", "enum": ["file_exists", "command_success", "content_match", "manual", "automated_test"]},
            "criteria": {"type": "string"}
          }
        },
        "permissions": {"type": "string", "enum": ["readonly", "restricted", "all"], "default": "restricted"},
        "timeout": {"type": "integer", "default": 30},
        "retry_on_error": {"type": "boolean", "default": false},
        "error_handling": {
          "type": "object",
          "properties": {
            "escalate_to": {"type": "string", "enum": ["sonnet-debugger", "opus-planner"]},
            "max_retries": {"type": "integer", "default": 0}
          }
        },
        "result": {
          "type": "object",
          "properties": {
            "status": {"type": "string", "enum": ["success", "error", "timeout"]},
            "output": {"type": "string"},
            "error_message": {"type": "string"},
            "execution_time": {"type": "number"},
            "executed_by": {"type": "string"},
            "executed_at": {"type": "string", "format": "date-time"}
          }
        }
      }
    }
  }
}
