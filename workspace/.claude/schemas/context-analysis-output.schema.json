{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://claude-code.dev/schemas/context-analysis-output.schema.json",
  "title": "Context Analysis Output",
  "description": "Structured output from analyze-context.py script",
  "version": "1.0.0",
  "type": "object",
  "required": ["version", "timestamp", "project", "state", "todos", "relationships"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp of analysis",
      "format": "date-time"
    },
    "project": {
      "type": "object",
      "description": "Project metadata from CLAUDE.md",
      "required": ["name", "type", "location"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Project name"
        },
        "type": {
          "type": "string",
          "description": "Project type",
          "enum": ["python", "nodejs", "typescript", "multi-language", "other"]
        },
        "location": {
          "type": "string",
          "description": "Absolute path to project root"
        },
        "tech_stack": {
          "type": "array",
          "description": "Technologies and frameworks used",
          "items": {
            "type": "string"
          }
        },
        "architecture": {
          "type": "string",
          "description": "Architecture pattern summary"
        },
        "entry_points": {
          "type": "array",
          "description": "Commands to run the project",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "command": {
                "type": "string"
              },
              "description": {
                "type": "string"
              }
            }
          }
        },
        "virtual_env": {
          "type": "string",
          "description": "Path to virtual environment (if applicable)"
        },
        "key_files": {
          "type": "array",
          "description": "Important files and their purposes",
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string"
              },
              "purpose": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "state": {
      "type": "object",
      "description": "Current project state from state.md",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "description": "Overall status",
          "enum": ["active", "blocked", "waiting", "completed", "deprecated"]
        },
        "current_focus": {
          "type": "string",
          "description": "What's currently being worked on"
        },
        "working_features": {
          "type": "array",
          "description": "Features that are operational",
          "items": {
            "type": "string"
          }
        },
        "in_progress": {
          "type": "array",
          "description": "Work currently in progress",
          "items": {
            "type": "string"
          }
        },
        "blockers": {
          "type": "array",
          "description": "Current blockers and issues",
          "items": {
            "type": "object",
            "properties": {
              "description": {
                "type": "string"
              },
              "severity": {
                "type": "string",
                "enum": ["low", "medium", "high", "critical"]
              },
              "since": {
                "type": "string",
                "format": "date"
              }
            }
          }
        },
        "recent_changes": {
          "type": "array",
          "description": "Recent changes and updates",
          "items": {
            "type": "object",
            "properties": {
              "date": {
                "type": "string",
                "format": "date"
              },
              "description": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "todos": {
      "type": "object",
      "description": "Tasks from todo.md",
      "properties": {
        "high_priority": {
          "type": "array",
          "description": "High priority tasks",
          "items": {
            "$ref": "#/definitions/task"
          }
        },
        "current_sprint": {
          "type": "array",
          "description": "Current sprint goals and tasks",
          "items": {
            "type": "object",
            "properties": {
              "goal": {
                "type": "string"
              },
              "tasks": {
                "type": "array",
                "items": {
                  "$ref": "#/definitions/task"
                }
              }
            }
          }
        },
        "backlog": {
          "type": "array",
          "description": "Backlog tasks",
          "items": {
            "$ref": "#/definitions/task"
          }
        }
      }
    },
    "relationships": {
      "type": "object",
      "description": "Project relationships and dependencies",
      "properties": {
        "parent_projects": {
          "type": "array",
          "description": "Projects this depends on",
          "items": {
            "type": "string"
          }
        },
        "child_projects": {
          "type": "array",
          "description": "Projects that depend on this",
          "items": {
            "type": "string"
          }
        },
        "integrations": {
          "type": "array",
          "description": "External integrations",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "type": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": ["active", "planned", "deprecated"]
              }
            }
          }
        }
      }
    },
    "seed_rules": {
      "type": "object",
      "description": "Extracted seed rules from project context",
      "properties": {
        "project_level": {
          "type": "array",
          "description": "High-level principles",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "description": {
                "type": "string"
              }
            }
          }
        },
        "section_level": {
          "type": "array",
          "description": "Feature-specific patterns",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "pattern": {
                "type": "string"
              }
            }
          }
        },
        "task_level": {
          "type": "array",
          "description": "Implementation guidelines",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "guideline": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "research_needs": {
      "type": "array",
      "description": "Topics that need research",
      "items": {
        "type": "object",
        "properties": {
          "topic": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "enum": ["framework", "standard", "best_practice", "example", "security"]
          },
          "priority": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "reason": {
            "type": "string"
          }
        }
      }
    }
  },
  "definitions": {
    "task": {
      "type": "object",
      "required": ["id", "description", "status"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique task identifier"
        },
        "description": {
          "type": "string",
          "description": "Task description"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "in_progress", "completed", "blocked"],
          "description": "Task status"
        },
        "priority": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "dependencies": {
          "type": "array",
          "description": "Task IDs this depends on",
          "items": {
            "type": "string"
          }
        },
        "resources": {
          "type": "array",
          "description": "Resources needed",
          "items": {
            "type": "string"
          }
        },
        "expected_outcome": {
          "type": "string",
          "description": "What success looks like"
        }
      }
    }
  }
}
