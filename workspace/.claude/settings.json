{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash {{WORKSPACE_ROOT}}/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash {{WORKSPACE_ROOT}}/.claude/hooks/session-stop.sh"
          }
        ]
      }
    ]
  },
  "models": {
    "planning": "opus",
    "execution": "haiku",
    "debugging": "sonnet",
    "tracking": "sonnet"
  }
}
