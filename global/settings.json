{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash",
      "Task",
      "TodoWrite",
      "WebSearch",
      "WebFetch",
      "NotebookEdit",
      "Skill",
      "SlashCommand",
      "AskUserQuestion",
      "EnterPlanMode",
      "ExitPlanMode",
      "KillShell",
      "TaskOutput",
      "mcp__*",
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "Task(*)",
      "Skill(*)",
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(git:*)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(pip:*)",
      "Bash(npm:*)",
      "Bash(node:*)",
      "Bash(docker:*)",
      "Bash(systemctl:*)",
      "Bash(chmod:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(/bin/bash:*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(fdisk:*)",
      "Write(//etc/passwd)",
      "Write(//etc/shadow)",
      "Edit(//etc/passwd)",
      "Edit(//etc/shadow)"
    ],
    "ask": [
      "Bash(sudo su)",
      "Bash(chmod 777:*)",
      "Bash(iptables -F)",
      "Bash(ufw --force reset)",
      "Bash(systemctl stop:*)",
      "Bash(systemctl disable:*)"
    ],
    "defaultMode": "plan"
  },
  "enabledPlugins": {
    "maestro@local": true,
    "commit-commands@claude-code-plugins": true,
    "github@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "document-skills@anthropic-agent-skills": true,
    "code-review@claude-plugins-official": true,
    "frontend-design@claude-code-plugins": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "model": "sonnet"
}
